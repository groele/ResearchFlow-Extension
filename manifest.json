{
  "manifest_version": 3,
  "name": "ResearchFlow Companion",
  "version": "1.0.0",
  "description": "Your ultimate research operating system sidekick. Capture literature, take notes, manage projects, and sync perfectly across your private cloud drives.",
  "icons": {
    "16": "assets/icons/icon.svg",
    "48": "assets/icons/icon.svg",
    "128": "assets/icons/icon.svg"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "unlimitedStorage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://graph.microsoft.com/*",
    "https://www.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.deepseek.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_title": "ResearchFlow Quick Panel",
    "default_icon": {
      "16": "assets/icons/icon.svg",
      "48": "assets/icons/icon.svg",
      "128": "assets/icons/icon.svg"
    }
  },
  "options_page": "pages/options.html",
  "side_panel": {
    "default_path": "pages/sidepanel.html"
  },
  "minimum_chrome_version": "116"
}
